            padding-bottom: 20px;
            border-bottom: 1px solid #fce4ec;
         }
         .avatar-circle {
            width: 45px;
            height: 45px;
            background: var(--color-sub);
            color: var(--color-red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            flex-shrink: 0;
         }
         .comment-content h5 {
            margin: 0 0 5px 0;
            color: #333;
            font-size: 15px;
         }
         .comment-content p {
            margin: 0;
            font-size: 14px;
            color: #555;
