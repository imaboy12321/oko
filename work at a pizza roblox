            padding: 0 20px;
         }
         .footer-section h4 {
            color: #ffeb3b;
            font-size: 16px;
            margin-bottom: 20px;
            font-weight: 800;
            text-transform: uppercase;
         }
         .footer-section p {
            font-size: 14px;
            line-height: 1.8;
            margin: 10px 0;
            opacity: 0.9;
         }
         .footer-section a {
            color: white;
            text-decoration: none;
            transition: 0.3s;
            border-bottom: 1px dashed rgba(255, 255, 255, 0.5);
         }
         .footer-section a:hover {
            color: #ffeb3b;
