         }
         .thatlac-entry h4 {
            margin: 0 0 5px 0;
            font-size: 14px;
            color: #d81b60;
         }
         .thatlac-entry h4 a {
            text-decoration: none;
            color: #333;
            font-weight: 700;
            line-height: 1.4;
            display: block;
            transition: 0.2s;
         }
         .thatlac-entry a:hover {
            color: var(--color-main);
         }
         .thatlac-entry p {
            margin: 0;
            font-size: 12px;
            color: #666;
         }
         .petal {
            position: fixed;
            top: -10%;
            z-index: 9999;
            user-select: none;
            pointer-events: none;
            animation: fall linear infinite;
         }
         @keyframes fall {
            0% {
               top: -10%;
               transform: translateX(0) rotate(0deg);
               opacity: 1;
            }
            100% {
               top: 100%;
               transform: translateX(150px) rotate(360deg);
               opacity: 0.3;
            }
         }
         .anh {
            padding: 80px 0;
            background: url("https://c3chuvanan.edu.vn/wp-content/uploads/2025/07/bg-anh2.png")
               center/cover no-repeat;
         }
         .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
         }
         .anh-title {
            color: black;
            font-size: 38px;
            font-weight: 800;
            text-align: center;
            margin-bottom: 50px;
            text-transform: uppercase;
         }
         .blaze-track {
            display: flex;
            align-items: stretch;
         }
         .anh__item {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
