         .video-side-item:hover span {
            color: var(--color-main);
         }
         .comment-section {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
         }
         .comment-wrapper {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(216, 27, 96, 0.08);
            border: 1px solid #fce4ec;
         }
         .comment-title {
            color: var(--color-red);
            font-size: 22px;
            font-weight: 800;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
         }
         .comment-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 40px;
         }
         .comment-form input,
