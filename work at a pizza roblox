            box-shadow: 0 10px 30px rgba(216, 27, 96, 0.08);
            border-bottom: 4px solid var(--color-main);
         }
         .video-header {
            background: var(--color-sub);
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
         }
