                  const name = document.getElementById("user-name").value;
                  const msg = document.getElementById("user-msg").value;
                  const container =
                     document.getElementById("comment-container");
                  const initials = name.substring(0, 2).toUpperCase();
                  const newComment = `          <div class="comment-item" style="animation: fadeIn 0.5s ease;">            <div class="avatar-circle">${initials}</div>            <div class="comment-content">              <h5>${name}</h5>              <p>${msg}</p>              <div class="comment-time">Vừa xong</div>            </div>          </div>        `;
                  container.insertAdjacentHTML("afterbegin", newComment);
                  this.reset();
               });
            }
         });
      </script>
      <script>
         function createPetal() {
            const petals = ["🌸", "🌹", "🌺", "🌷", "💖"];
            const div = document.createElement("div");
            div.className = "petal";
            div.innerHTML = petals[Math.floor(Math.random() * petals.length)];
            div.style.left = Math.random() * 100 + "vw";
            div.style.animationDuration = Math.random() * 5 + 5 + "s";
            div.style.fontSize = Math.random() * 10 + 15 + "px";
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 8000);
         }
         setInterval(createPetal, 800);
      </script>
      <style>
         @keyframes fadeIn {
            from {
               opacity: 0;
               transform: translateY(10px);
            }
            to {
               opacity: 1;
               transform: translateY(0);
            }
         }
      </style>
   </body>
</html>
